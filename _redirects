# Buyzo Cart — URL Redirects (Netlify)
# Yeh file /public ya root folder mein rakhein

# API Redirects for Razorpay Payment Gateway
/api/create-order     /.netlify/functions/create-order   200
/api/verify-payment   /.netlify/functions/verify-payment 200
/api/owner-vault/*    /.netlify/functions/owner-vault    200

# .html URLs ko clean URLs pe redirect karo
/owner-vault.html    /owner-vault       301
/account.html        /account           301
/refund.html         /refund            301
/privacy.html        /privacy           301
/shipping.html       /shipping          301
/terms.html          /terms             301
/contact.html        /contact           301
/sellproduct.html    /sellproduct       301

# Clean URLs ko actual HTML files pe serve karo (200 = rewrite, not redirect)
/owner-vault         /owner-vault.html  200
/account             /account.html      200
/refund              /refund.html       200
/privacy             /privacy.html      200
/shipping            /shipping.html     200
/terms               /terms.html        200
/contact             /contact.html      200
/sellproduct         /sellproduct.html  200
